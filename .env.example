# ============================================================
# IvisAllConst — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA commitees el .env real.
# ============================================================

NODE_ENV=development

# ---- Postgres ----
POSTGRES_USER=ivisallconst
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=ivisallconst
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ivisallconst:change-me-in-prod@postgres:5432/ivisallconst?schema=public

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- Backend ----
BACKEND_PORT=4000
JWT_ACCESS_SECRET=replace-with-64+chars-random-string
JWT_REFRESH_SECRET=replace-with-another-64+chars-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_COST=12
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOG_LEVEL=info

# ---- Frontend ----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ---- Seed admin ----
SEED_ADMIN_EMAIL=admin@ivisallconst.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=IvisAllConst
