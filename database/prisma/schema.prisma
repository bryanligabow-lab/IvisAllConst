// IvisAllConst — Esquema de base de datos
// Producción: PostgreSQL (Railway lo provee vía DATABASE_URL).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH / RBAC
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  deleteCodeHash String?  @map("delete_code_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  avatarUrl     String?   @map("avatar_url")
  emailVerified Boolean   @default(false) @map("email_verified")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  roles                UserRole[]
  projectAssignments   ProjectAssignment[]      @relation("AssignmentUser")
  refreshTokens        RefreshToken[]
  passwordResets       PasswordResetToken[]
  emailVerifTokens     EmailVerificationToken[]
  auditLogs            AuditLog[]
  assignedRoles        UserRole[]               @relation("AssignedBy")
  createdProjects      Project[]                @relation("CreatedBy")
  createdGastos        Gasto[]                  @relation("GastoCreatedBy")
  createdPlanillas     Planilla[]               @relation("PlanillaCreatedBy")
  createdPaymentOrders PaymentOrder[]           @relation("PaymentOrderCreatedBy")
  createdProviders     Provider[]               @relation("ProviderCreatedBy")
  createdEmployees     Employee[]               @relation("EmployeeCreatedBy")
  createdProformas     Proforma[]               @relation("ProformaCreatedBy")
  createdClients       Client[]                 @relation("ClientCreatedBy")
  createdProducts      Product[]                @relation("ProductCreatedBy")
  uploadedDocuments    ProjectDocument[]        @relation("DocUploadedBy")
  createdAttendance    Attendance[]             @relation("AttendanceCreatedBy")
  createdBitacora      BitacoraEntry[]          @relation("BitacoraCreatedBy")

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedBy String?  @map("assigned_by")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  deviceInfo String?   @map("device_info")
  ipAddress  String?   @map("ip_address")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model LoginAttempt {
  id        String   @id @default(uuid())
  email     String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  success   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  oldValues  String?  @map("old_values") // JSON serializado
  newValues  String?  @map("new_values") // JSON serializado
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// DOMINIO — Gestión de obra
// SQLite no soporta enums; usamos String con validación en zod.
// ============================================================

model Project {
  id               String    @id @default(uuid())
  code             String    @unique
  name             String
  contractor       String?
  // Cliente que solicita el contrato (catálogo de clientes).
  clientId         String?   @map("client_id")
  // Quién ejecuta la obra: OWN (CREACOM) | SUBCONTRACTED.
  executionType    String    @default("OWN") @map("execution_type")
  // Subcontratista (proveedor) cuando executionType = SUBCONTRACTED.
  subcontractorId  String?   @map("subcontractor_id")
  description      String?
  city             String?
  latitude         Float?
  longitude        Float?
  contractAmount   Float     @default(0) @map("contract_amount")
  advancePercent   Float     @default(40) @map("advance_percent")
  guaranteePercent Float     @default(5) @map("guarantee_percent")
  // IVA — los presupuestos se ingresan como base o ya incluido.
  vatPercent       Float     @default(15) @map("vat_percent")
  vatIncluded      Boolean   @default(false) @map("vat_included")
  // Retenciones cuando el cliente es agente de retención.
  isWithholdingAgent     Boolean @default(false) @map("is_withholding_agent")
  vatRetentionPercent    Float   @default(0) @map("vat_retention_percent")
  incomeRetentionPercent Float   @default(0) @map("income_retention_percent")
  // % de ganancia de CREACOM cuando la obra es subcontratada.
  creacomProfitPercent   Float   @default(0) @map("creacom_profit_percent")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  status           String    @default("DRAFT") // DRAFT | ACTIVE | PAUSED | COMPLETED | CANCELLED
  createdBy        String    @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  creator       User           @relation("CreatedBy", fields: [createdBy], references: [id])
  client        Client?        @relation("ClientProjects", fields: [clientId], references: [id])
  subcontractor Provider?      @relation("ProjectSubcontractor", fields: [subcontractorId], references: [id])
  rubros        Rubro[]
  gastos        Gasto[]
  planillas     Planilla[]
  paymentOrders PaymentOrder[]
  employees     Employee[]
  proformas     Proforma[]
  documents     ProjectDocument[]
  assignments   ProjectAssignment[]
  attendance    Attendance[]
  bitacora      BitacoraEntry[]

  @@index([code])
  @@index([status])
  @@index([clientId])
  @@index([subcontractorId])
  @@index([deletedAt])
  @@map("projects")
}

model ProjectDocument {
  id         String    @id @default(uuid())
  projectId  String    @map("project_id")
  label      String?
  filename   String
  mimeType   String    @map("mime_type")
  fileSize   Int       @map("file_size")
  data       Bytes
  uploadedBy String    @map("uploaded_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User    @relation("DocUploadedBy", fields: [uploadedBy], references: [id])

  @@index([projectId])
  @@index([deletedAt])
  @@map("project_documents")
}

// Asignación usuario ↔ proyecto. Define a qué proyectos puede acceder un
// operador (residente). Los roles admin/super_admin ignoran esta restricción.
model ProjectAssignment {
  userId     String   @map("user_id")
  projectId  String   @map("project_id")
  assignedBy String?  @map("assigned_by")
  createdAt  DateTime @default(now()) @map("created_at")

  user    User    @relation("AssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("project_assignments")
}

model Rubro {
  id             String    @id @default(uuid())
  projectId      String    @map("project_id")
  code           String
  name           String
  unit           String?
  quantity       Float     @default(0)
  unitPrice      Float     @default(0) @map("unit_price")
  // % de utilidad sobre cantidad × precio (margen de ganancia incluido en el presupuesto).
  utilityPercent Float     @default(0) @map("utility_percent")
  // Si true, al monto presupuestado se le agrega el IVA del proyecto al calcular reportes.
  includesVat    Boolean   @default(false) @map("includes_vat")
  budgetedAmount Float     @default(0) @map("budgeted_amount")
  orderIndex     Int       @default(0) @map("order_index")
  parentId       String?   @map("parent_id")
  isGroup        Boolean   @default(false) @map("is_group")
  // Subcontratación parcial: un rubro puede ejecutarlo un subcontratista (proveedor)
  // con un valor a pagar que puede cambiar en el tiempo.
  subcontractorId   String?  @map("subcontractor_id")
  subcontractAmount Float?   @map("subcontract_amount")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent        Rubro?         @relation("RubroChildren", fields: [parentId], references: [id])
  children      Rubro[]        @relation("RubroChildren")
  subcontractor Provider?      @relation("RubroSubcontractor", fields: [subcontractorId], references: [id])
  gastos             Gasto[]
  planillaItems      PlanillaItem[]
  paymentOrders      PaymentOrder[]
  paymentOrderItems  PaymentOrderItem[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([parentId])
  @@index([subcontractorId])
  @@map("rubros")
}

model Gasto {
  id             String    @id @default(uuid())
  projectId      String    @map("project_id")
  rubroId        String    @map("rubro_id")
  description    String
  invoiceNumber  String?   @map("invoice_number")
  amount         Float
  gastoDate      DateTime  @map("gasto_date")
  attachmentUrl  String?   @map("attachment_url")
  paymentOrderId String?   @map("payment_order_id")
  providerId     String?   @map("provider_id")
  employeeId     String?   @map("employee_id")
  kind           String    @default("EXPENSE") // EXPENSE | PAYROLL | THIRD_PARTY
  paymentMethod  String?   @map("payment_method")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rubro        Rubro         @relation(fields: [rubroId], references: [id])
  creator      User          @relation("GastoCreatedBy", fields: [createdBy], references: [id])
  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [id])
  provider     Provider?     @relation(fields: [providerId], references: [id])
  employee     Employee?     @relation(fields: [employeeId], references: [id])

  @@index([projectId, gastoDate])
  @@index([rubroId])
  @@index([paymentOrderId])
  @@index([providerId])
  @@index([employeeId])
  @@index([deletedAt])
  @@map("gastos")
}

model Planilla {
  id                  String    @id @default(uuid())
  projectId           String    @map("project_id")
  number              Int
  title               String
  periodStart         DateTime  @map("period_start")
  periodEnd           DateTime  @map("period_end")
  status              String    @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | PAID | CANCELLED
  totalCurrent        Float     @default(0) @map("total_current")
  totalPrevious       Float     @default(0) @map("total_previous")
  totalAccumulated    Float     @default(0) @map("total_accumulated")
  advanceAmortization Float     @default(0) @map("advance_amortization")
  guaranteeRetention  Float     @default(0) @map("guarantee_retention")
  netPayable          Float     @default(0) @map("net_payable")
  createdBy           String    @map("created_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User           @relation("PlanillaCreatedBy", fields: [createdBy], references: [id])
  items   PlanillaItem[]

  @@unique([projectId, number])
  @@index([projectId])
  @@map("planillas")
}

model PlanillaItem {
  id                String   @id @default(uuid())
  planillaId        String   @map("planilla_id")
  rubroId           String   @map("rubro_id")
  executedQuantity  Float    @default(0) @map("executed_quantity")
  currentAmount     Float    @default(0) @map("current_amount")
  previousAmount    Float    @default(0) @map("previous_amount")
  accumulatedAmount Float    @default(0) @map("accumulated_amount")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  planilla Planilla @relation(fields: [planillaId], references: [id], onDelete: Cascade)
  rubro    Rubro    @relation(fields: [rubroId], references: [id])

  @@unique([planillaId, rubroId])
  @@index([planillaId])
  @@map("planilla_items")
}

model PaymentOrder {
  id            String    @id @default(uuid())
  projectId     String    @map("project_id")
  // Rubro principal. Opcional: una orden puede repartirse entre varios rubros
  // vía PaymentOrderItem (desglose de una factura por rubro).
  rubroId       String?   @map("rubro_id")
  providerId    String?   @map("provider_id")
  description   String
  amount        Float
  invoiceNumber String?   @map("invoice_number")
  paymentMethod String?   @map("payment_method") // CASH | TRANSFER | CHECK | CREDIT_CARD | DEBIT_CARD | OTHER
  scheduledDate DateTime  @map("scheduled_date")
  paidAt        DateTime? @map("paid_at")
  status        String    @default("PENDING") // PENDING | PAID | CANCELLED
  createdBy     String    @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  project  Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rubro    Rubro?             @relation(fields: [rubroId], references: [id])
  provider Provider?          @relation(fields: [providerId], references: [id])
  creator  User               @relation("PaymentOrderCreatedBy", fields: [createdBy], references: [id])
  gastos   Gasto[]
  items    PaymentOrderItem[]

  @@index([projectId, scheduledDate])
  @@index([rubroId])
  @@index([providerId])
  @@index([status])
  @@index([deletedAt])
  @@map("payment_orders")
}

// Desglose de una orden de pago (una factura) entre varios rubros.
model PaymentOrderItem {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  rubroId   String   @map("rubro_id")
  amount    Float
  createdAt DateTime @default(now()) @map("created_at")

  order PaymentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rubro Rubro        @relation(fields: [rubroId], references: [id])

  @@index([orderId])
  @@index([rubroId])
  @@map("payment_order_items")
}

model Provider {
  id        String    @id @default(uuid())
  name      String
  ruc       String?
  phone     String?
  email     String?
  service   String?
  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  creator              User           @relation("ProviderCreatedBy", fields: [createdBy], references: [id])
  gastos               Gasto[]
  paymentOrders        PaymentOrder[]
  // Proyectos en los que actúa como subcontratista.
  subcontractedProjects Project[]     @relation("ProjectSubcontractor")
  // Rubros (parciales) que ejecuta como subcontratista.
  subcontractedRubros   Rubro[]       @relation("RubroSubcontractor")

  @@index([name])
  @@index([deletedAt])
  @@map("providers")
}

model Employee {
  id            String    @id @default(uuid())
  fullName      String    @map("full_name")
  cedula        String?   @unique
  position      String?
  monthlySalary Float     @default(0) @map("monthly_salary")
  email         String?
  phone         String?
  hireDate      DateTime? @map("hire_date")
  endDate       DateTime? @map("end_date")
  status        String    @default("ACTIVE") // ACTIVE | INACTIVE
  projectId     String?   @map("project_id")
  createdBy     String    @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  project    Project?     @relation(fields: [projectId], references: [id])
  creator    User         @relation("EmployeeCreatedBy", fields: [createdBy], references: [id])
  gastos     Gasto[]
  attendance Attendance[]

  @@index([fullName])
  @@index([projectId])
  @@index([deletedAt])
  @@map("employees")
}

// Asistencia diaria de personal por proyecto (Fase 2 — Nómina).
model Attendance {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  projectId  String   @map("project_id")
  date       DateTime
  status     String   @default("PRESENT") // PRESENT | ABSENT | LATE | PERMISSION | REST
  // Hora de entrada/salida (formato "HH:MM"), opcionales.
  checkIn    String?  @map("check_in")
  checkOut   String?  @map("check_out")
  notes      String?
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator  User     @relation("AttendanceCreatedBy", fields: [createdBy], references: [id])

  @@unique([employeeId, date])
  @@index([projectId, date])
  @@map("attendance")
}

// Bitácora / libro de obra: registro diario por proyecto (Fase 2).
model BitacoraEntry {
  id        String    @id @default(uuid())
  projectId String    @map("project_id")
  date      DateTime
  weather   String?
  workforce Int?
  title     String?
  content   String
  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation("BitacoraCreatedBy", fields: [createdBy], references: [id])
  photos  BitacoraPhoto[]

  @@index([projectId, date])
  @@index([deletedAt])
  @@map("bitacora_entries")
}

// Fotos adjuntas a una entrada de bitácora (libro de obra).
model BitacoraPhoto {
  id        String   @id @default(uuid())
  entryId   String   @map("entry_id")
  mimeType  String   @map("mime_type")
  data      Bytes
  caption   String?
  createdAt DateTime @default(now()) @map("created_at")

  entry BitacoraEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@map("bitacora_photos")
}

model Proforma {
  id                String    @id @default(uuid())
  number            String    @unique
  date              DateTime
  clientId          String?   @map("client_id")
  clientName        String    @map("client_name")
  clientRuc         String?   @map("client_ruc")
  clientAddress     String?   @map("client_address")
  clientResponsible String?   @map("client_responsible")
  projectLabel      String?   @map("project_label")
  projectId         String?   @map("project_id")
  ivaPercent        Float     @default(15) @map("iva_percent")
  creditTerm        String?   @map("credit_term")
  paymentTerms      String?   @map("payment_terms")
  validity          String?
  topClients        String?   @map("top_clients") // newline-separated
  signerName        String?   @map("signer_name")
  signerTitle       String?   @map("signer_title")
  notes             String?
  status            String    @default("DRAFT") // DRAFT | SENT | APPROVED | REJECTED
  createdBy         String    @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  project Project?        @relation(fields: [projectId], references: [id])
  client  Client?         @relation(fields: [clientId], references: [id])
  creator User            @relation("ProformaCreatedBy", fields: [createdBy], references: [id])
  items   ProformaItem[]
  images  ProformaImage[]

  @@index([number])
  @@index([date])
  @@index([projectId])
  @@index([clientId])
  @@index([deletedAt])
  @@map("proformas")
}

model ProformaItem {
  id          String   @id @default(uuid())
  proformaId  String   @map("proforma_id")
  orderIndex  Int      @default(0) @map("order_index")
  quantity    Float
  unit        String
  description String
  unitPrice   Float    @map("unit_price")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  proforma Proforma @relation(fields: [proformaId], references: [id], onDelete: Cascade)

  @@index([proformaId])
  @@map("proforma_items")
}

model Client {
  id          String    @id @default(uuid())
  name        String
  ruc         String?
  address     String?
  responsible String?
  email       String?
  phone       String?
  notes       String?
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  creator   User       @relation("ClientCreatedBy", fields: [createdBy], references: [id])
  proformas Proforma[]
  projects  Project[]  @relation("ClientProjects")

  @@index([name])
  @@index([deletedAt])
  @@map("clients")
}

// Catálogo de productos/servicios reutilizables para las proformas.
// El usuario guarda SOLO los que se repiten; al armar una proforma elige el
// producto (llena unidad/descripción/precio) y solo ajusta cantidad/precio.
model Product {
  id          String    @id @default(uuid())
  name        String
  unit        String    @default("U")
  description String
  unitPrice   Float     @default(0) @map("unit_price")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  creator User @relation("ProductCreatedBy", fields: [createdBy], references: [id])

  @@index([name])
  @@index([deletedAt])
  @@map("products")
}

model ProformaImage {
  id         String   @id @default(uuid())
  proformaId String   @map("proforma_id")
  orderIndex Int      @default(0) @map("order_index")
  // Índice del ítem (orderIndex) al que pertenece la imagen. Null = imagen
  // general de la proforma (se muestra al final).
  itemIndex  Int?     @map("item_index")
  filename   String?
  mimeType   String   @map("mime_type")
  data       Bytes
  caption    String?
  createdAt  DateTime @default(now()) @map("created_at")

  proforma Proforma @relation(fields: [proformaId], references: [id], onDelete: Cascade)

  @@index([proformaId])
  @@map("proforma_images")
}
